@model IEnumerable<havenix.Models.Movie>

@{
    ViewBag.Title = "Danh sách phim";
}

<div class="movies-page">

    <div class="movies-header">

        <h2>DANH SÁCH PHIM</h2>

        <p>
            Khám phá những bộ phim hấp dẫn đang chiếu và sắp chiếu tại HAVENIX.
        </p>

    </div>

    <div class="movies-grid">

        @foreach (var item in Model)
        {
            var firstShowtime = item.Showtimes?
                .OrderBy(x => x.StartTime)
                .FirstOrDefault();

            <div class="movies-card">

                <div class="movie-poster">

                    <img src="@Url.Content(item.Image)"
                         alt="@item.Name" />

                    <span class="movie-status">
                        @(string.IsNullOrEmpty(item.Status)
                            ? "Đang chiếu"
                            : item.Status)
                    </span>

                </div>

                <div class="movies-info">

                    <h3>@item.Name</h3>

                    <p>
                        <b>Thể loại:</b> @item.Genre
                    </p>

                    <p>
                        <b>Thời lượng:</b> @item.Duration
                    </p>

                    <p>
                        <b>Khởi chiếu:</b> @item.ReleaseDate
                    </p>

                </div>

                <div class="movies-actions">

                    <a href="@Url.Action("Details", "Movies", new { id = item.Id })"
                       class="btn-detail">
                        Xem chi tiết
                    </a>

                    @if (firstShowtime != null)
                    {
                        <a href="@Url.Action("Create", "Booking", new { showtimeId = firstShowtime.Id })"
                           class="btn-book">
                            Đặt vé
                        </a>
                    }
                    else
                    {
                        <a href="@Url.Action("Details", "Movies", new { id = item.Id })"
                           class="btn-book">
                            Chưa có suất
                        </a>
                    }

                </div>

            </div>
        }

    </div>

</div>