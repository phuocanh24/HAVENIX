@model IEnumerable<havenix.Models.Movie>

@{
    ViewBag.Title = "Danh sách phim";
}

<div class="movies-page">

    <h2>DANH SÁCH PHIM</h2>

    <div class="movies-grid">

        @foreach (var item in Model)
        {
            <div class="movies-card">

                <a href="@Url.Action("Details", "Movies", new { id = item.Id })"
                   class="movies-link">

                    <img src="@Url.Content(item.Image)" alt="@item.Name" />

                    <div class="movies-info">
                        <h3>@item.Name</h3>
                        <p><b>Thể loại:</b> @item.Genre</p>
                        <p><b>Thời lượng:</b> @item.Duration</p>
                        <p><b>Ngày chiếu:</b> @item.ReleaseDate</p>
                    </div>

                </a>

                <a href="@Url.Action("Details", "Movies", new { id = item.Id })"
                   class="movies-btn">
                    Xem lịch chiếu
                </a>

            </div>
        }

    </div>

</div>