@model IEnumerable<havenix.Models.Movie>

@{
    ViewBag.Title = "Danh sách phim";
}

<div class="movies-page">

    @if (ViewBag.Keyword != null)
    {
        <div class="alert alert-info">
            Kết quả tìm kiếm cho:
            <strong>@ViewBag.Keyword</strong>
        </div>

        if (!Model.Any())
        {
            <div class="alert alert-warning">
                Không tìm thấy phim phù hợp.
            </div>
        }
    }


    <div class="movie-filters">

        @using (Html.BeginForm("Index", "Movies", FormMethod.Get))
        {
            <select name="genre">
                <option value="">Tất cả thể loại</option>

                @foreach (string g in ViewBag.Genres)
                {
                    <option value="@g"
                            @(ViewBag.SelectedGenre == g ? "selected" : "")>
                        @g
                    </option>
                }
            </select>

            <select name="status">
                <option value="">Tất cả trạng thái</option>

                @foreach (string s in ViewBag.Statuses)
                {
                    <option value="@s"
                            @(ViewBag.SelectedStatus == s ? "selected" : "")>
                        @s
                    </option>
                }
            </select>

            <button type="submit" class="btn-filter">
                Lọc
            </button>
        }

    </div>

    <div class="movies-grid">

        @foreach (var item in Model)
        {
            var firstShowtime = item.Showtimes?
                .OrderBy(x => x.StartTime)
                .FirstOrDefault();

            <div class="movies-card">

                <div class="movie-poster">

                    <img src="@Url.Content(item.Image)"
                         alt="@item.Name" />

                    <span class="movie-status">
                        @(string.IsNullOrEmpty(item.Status)
                            ? "Đang chiếu"
                            : item.Status)
                    </span>

                </div>

                <div class="movies-info">

                    <h3>@item.Name</h3>

                    <p>
                        <b>Thể loại:</b> @item.Genre
                    </p>

                    <p>
                        <b>Thời lượng:</b> @item.DurationText
                    </p>

                    <p>
                        <b>Khởi chiếu:</b> @item.ReleaseDateText
                    </p>

                </div>

                <div class="movies-actions">

                    <a href="@Url.Action("Details", "Movies", new { id = item.Id })"
                       class="btn-detail">
                        Xem chi tiết
                    </a>

                    @if (firstShowtime != null)
                    {
                        <a href="@Url.Action("Create", "Booking", new { showtimeId = firstShowtime.Id })"
                           class="btn-book">
                            Đặt vé
                        </a>
                    }
                    else
                    {
                        <a href="@Url.Action("Details", "Movies", new { id = item.Id })"
                           class="btn-book">
                            Chưa có suất
                        </a>
                    }

                </div>

            </div>
        }

    </div>

</div>