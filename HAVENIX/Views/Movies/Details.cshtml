@model havenix.Models.Movie

@{
    ViewBag.Title = Model.Name;

    var grouped = Model.Showtimes
        .GroupBy(x => x.StartTime.Date)
        .OrderBy(x => x.Key)
        .ToList();
}

<div class="movie-detail-box">

    <div class="detail-poster">
        <img src="@Url.Content(Model.Image)" alt="@Model.Name" />
    </div>

    <div class="detail-info">

        <span class="detail-badge">Đang chiếu</span>

        <h1>@Model.Name</h1>

        <div class="detail-meta">
            <span>@Model.Genre</span>
            <span>@Model.Duration</span>
            <span>@Model.Language</span>
        </div>

        <hr />

        <div class="detail-section">
            <h3>Thông tin phim</h3>

            <p><b>Đạo diễn:</b> Đang cập nhật</p>
            <p><b>Diễn viên:</b> Đang cập nhật</p>
            <p><b>Thể loại:</b> @Model.Genre</p>
            <p><b>Thời lượng:</b> @Model.Duration</p>
            <p><b>Ngôn ngữ:</b> @Model.Language</p>
        </div>

        <div class="detail-section">
            <h3>Độ tuổi</h3>
            <p>
                <b>Rated:</b>
                T18 - Phim được phổ biến đến người xem từ đủ 18 tuổi trở lên.
            </p>
        </div>

        <div class="detail-section">
            <h3>Nội dung phim</h3>
            <p>@Model.Description</p>
        </div>

        <a href="#showtimeBox" class="btn btn-warning detail-book-btn">
            Đặt vé ngay
        </a>

    </div>

</div>

<div id="showtimeBox" class="showtime-container movie-showtime-box">

    <h2>CHỌN LỊCH CHIẾU</h2>

    @if (!grouped.Any())
    {
        <div class="empty-showtime">
            Hiện chưa có lịch chiếu cho phim này.
        </div>
    }
    else
    {
        <div class="date-tabs">
            @foreach (var day in grouped)
            {
                <button type="button"
                        class="tab-btn"
                        data-day="@day.Key.ToString("yyyy-MM-dd")"
                        onclick="showDay(this)">
                    <span>@day.Key.ToString("dd/MM")</span>
                    <small>@day.Key.ToString("dddd")</small>
                </button>
            }
        </div>

        <div class="time-content">
            @foreach (var day in grouped)
            {
                <div class="time-group"
                     data-day="@day.Key.ToString("yyyy-MM-dd")"
                     style="display:none">

                    <h3>@day.Key.ToString("dddd - dd/MM/yyyy")</h3>

                    <div class="time-list">
                        @foreach (var item in day.OrderBy(x => x.StartTime))
                        {
                            <a href="@Url.Action("Create", "Booking", new { showtimeId = item.Id })"
                               class="time-btn">
                                @item.StartTime.ToString("HH:mm")
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    }

</div>

<script>
    function showDay(btn) {
        let day = btn.getAttribute("data-day");

        document.querySelectorAll(".date-tabs .tab-btn")
            .forEach(b => b.classList.remove("active"));

        btn.classList.add("active");

        document.querySelectorAll(".time-group")
            .forEach(x => x.style.display = "none");

        let target = document.querySelector(".time-group[data-day='" + day + "']");
        if (target) {
            target.style.display = "block";
        }
    }

    document.addEventListener("DOMContentLoaded", function () {
        let first = document.querySelector(".date-tabs .tab-btn");
        if (first) {
            first.click();
        }
    });
</script>