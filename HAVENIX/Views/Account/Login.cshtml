<div class="auth-page">
    <div class="auth-card">

        <h2>Đăng nhập</h2>
        <p class="auth-subtitle">Chào mừng bạn quay lại HAVENIX</p>

        @using (Html.BeginForm())
        {
            <div class="form-group">
                <label>Email</label>
                <input name="email" type="email" placeholder="Nhập email" class="form-control" />
            </div>

            <div class="form-group">
                <label>Mật khẩu</label>
                <input type="password" name="password" placeholder="Nhập mật khẩu" class="form-control" />
            </div>

            if (ViewBag.Error != null)
            {
                <div class="auth-error">@ViewBag.Error</div>
            }

            <button type="submit" class="btn btn-warning auth-btn">
                Đăng nhập
            </button>

            <div class="auth-row">
                <label>
                    <input type="checkbox" />
                    Lưu mật khẩu
                </label>

                <a href="#">Quên mật khẩu?</a>
            </div>

            <div class="auth-bottom">
                Chưa có tài khoản?
                <a href="/Account/Register">Đăng ký ngay</a>
            </div>
        }

    </div>
</div>