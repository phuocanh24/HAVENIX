@model havenix.Models.User

<div class="auth-page">
    <div class="auth-card register-card">

        <h2>Đăng ký</h2>
        <p class="auth-subtitle">Tạo tài khoản để đặt vé nhanh hơn</p>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label>Họ và tên</label>
                <input name="FullName"
                       placeholder="Nhập họ và tên"
                       class="form-control"
                       required />
            </div>

            <div class="form-group">
                <label>Email</label>
                <input name="Email"

                       type="email"
                       placeholder="Nhập email"
                       class="form-control"
                       required />
            </div>

            <div class="form-group">
                <label>Số điện thoại</label>
                <input name="Phone"                      
                       placeholder="Nhập số điện thoại"
                       class="form-control"
                       required />
            </div>

            <div class="form-group">
                <label>Giới tính</label>
                <select name="Gender" class="form-control">
                    <option value="">-- Chọn giới tính --</option>
                    <option @(Model?.Gender == "Nam" ? "selected" : "")>Nam</option>
                    <option @(Model?.Gender == "Nữ" ? "selected" : "")>Nữ</option>
                    <option @(Model?.Gender == "Khác" ? "selected" : "")>Khác</option>
                </select>
            </div>

            <div class="form-group">
                <label>Ngày sinh</label>
                <input type="text"
                       name="BirthDate"
                       class="form-control"
                       placeholder="dd/mm/yyyy"
                       maxlength="10"
                       oninput="formatDate(this)"
                       required />
            </div>

            <div class="form-group">
                <label>Mật khẩu</label>
                <input type="password"
                       name="password"
                       placeholder="Nhập mật khẩu"
                       class="form-control"
                       required
                       minlength="6" />
            </div>

            <div class="form-group">
                <label>Nhập lại mật khẩu</label>
                <input type="password"
                       name="confirmPassword"
                       placeholder="Nhập lại mật khẩu"
                       class="form-control"
                       required
                       minlength="6" />
            </div>

            if (ViewBag.Error != null)
            {
                <div class="auth-error">@ViewBag.Error</div>
            }

            <button type="submit" class="btn btn-warning auth-btn">
                Đăng ký
            </button>

            <div class="auth-bottom">
                Đã có tài khoản?
                <a href="/Account/Login">Đăng nhập</a>
            </div>
        }

    </div>
</div>

<script>
    function formatDate(input) {
        let value = input.value.replace(/\D/g, '');

        if (value.length > 8) {
            value = value.slice(0, 8);
        }

        if (value.length >= 5) {
            value = value.slice(0, 2) + '/' + value.slice(2, 4) + '/' + value.slice(4);
        } else if (value.length >= 3) {
            value = value.slice(0, 2) + '/' + value.slice(2);
        }

        input.value = value;
    }
</script>