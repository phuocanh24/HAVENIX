@{
    ViewBag.Title = "Tiện Ích Online";
}

<div class="about-havenix-page">

    <div class="about-sidebar">
        <a href="@Url.Action("About","Home")">GIỚI THIỆU</a>
        <a class="active" href="@Url.Action("Online","Home")">TIỆN ÍCH ONLINE</a>
        <a href="@Url.Action("Contact","Home")">LIÊN HỆ HAVENIX</a>
        <a href="@Url.Action("GiftCard","Home")">THẺ QUÀ TẶNG</a>
        <a href="@Url.Action("Recruitment","Home")">TUYỂN DỤNG</a>
        <a href="@Url.Action("Advertising","Home")">LIÊN HỆ QUẢNG CÁO</a>
        <a href="@Url.Action("Terms","Home")">ĐIỀU KHOẢN CHUNG</a>
        <a href="@Url.Action("Transaction","Home")">ĐIỀU KHOẢN GIAO DỊCH</a>
        <a href="@Url.Action("Payment","Home")">CHÍNH SÁCH THANH TOÁN</a>
        <a href="@Url.Action("Privacy","Home")">CHÍNH SÁCH BẢO MẬT</a>
        <a href="@Url.Action("Rules","Home")">QUY ĐỊNH TẠI RẠP PHIM</a>
    </div>

    <div class="about-content">

        <h1>Tiện Ích Online</h1>

        <p>
            HAVENIX Cinema mang đến hệ thống tiện ích trực tuyến hiện đại giúp
            khách hàng dễ dàng tiếp cận các dịch vụ điện ảnh mọi lúc, mọi nơi.
        </p>

        <h3>🎬 Đặt Vé Trực Tuyến</h3>

        <p>
            Khách hàng có thể đặt vé xem phim trực tuyến nhanh chóng thông qua website.
            Hệ thống hỗ trợ lựa chọn phim, suất chiếu, ghế ngồi và thanh toán chỉ trong vài bước đơn giản.
        </p>

        <h3>🪑 Chọn Ghế Theo Thời Gian Thực</h3>

        <p>
            Sơ đồ ghế được cập nhật liên tục giúp khách hàng dễ dàng lựa chọn vị trí yêu thích
            và theo dõi tình trạng ghế còn trống trước khi thanh toán.
        </p>

        <h3>📱 Vé Điện Tử</h3>

        <p>
            Sau khi thanh toán thành công, vé điện tử sẽ được lưu trong tài khoản HAVENIX
            và có thể sử dụng trực tiếp tại rạp mà không cần in vé giấy.
        </p>

        <h3>🔍 Tra Cứu Lịch Chiếu</h3>

        <p>
            Hệ thống cho phép tra cứu lịch chiếu của tất cả các bộ phim đang chiếu
            và sắp chiếu một cách nhanh chóng và chính xác.
        </p>

        <h3>⭐ Tài Khoản Thành Viên</h3>

        <p>
            Khách hàng có thể đăng ký tài khoản thành viên để lưu lịch sử giao dịch,
            nhận ưu đãi đặc biệt và tham gia các chương trình chăm sóc khách hàng.
        </p>

        <h3>🎁 Khuyến Mãi Và Ưu Đãi</h3>

        <p>
            Các chương trình giảm giá, voucher và ưu đãi mới nhất sẽ được cập nhật
            thường xuyên trên hệ thống HAVENIX Cinema.
        </p>

        <h3>💳 Thanh Toán An Toàn</h3>

        <p>
            HAVENIX hỗ trợ nhiều phương thức thanh toán trực tuyến như ATM,
            Visa, MasterCard, ví điện tử và QR Code với tiêu chuẩn bảo mật cao.
        </p>

        <h3>📞 Hỗ Trợ Khách Hàng</h3>

        <p>
            Đội ngũ chăm sóc khách hàng luôn sẵn sàng hỗ trợ các vấn đề liên quan đến
            tài khoản, đặt vé, thanh toán và các dịch vụ khác của HAVENIX.
        </p>

        <h3>🔒 Bảo Mật Thông Tin</h3>

        <p>
            Thông tin cá nhân và giao dịch của khách hàng được bảo vệ bằng các biện pháp
            bảo mật hiện đại nhằm đảm bảo quyền riêng tư và an toàn dữ liệu.
        </p>

    </div>

</div>