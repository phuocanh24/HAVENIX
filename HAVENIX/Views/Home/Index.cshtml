        <div class="carousel-item">
            <img src="@Url.Content("~/Content/Img/banner6.jpg")" class="d-block w-100">
        </div>

        <div class="carousel-item">
            <img src="@Url.Content("~/Content/Img/banner7.jpg")" class="d-block w-100">
        </div>

        <div class="carousel-item">
