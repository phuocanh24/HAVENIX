@{
    ViewBag.Title = "Havenix Cinema";
}

<!-- BANNER -->
<div id="mainBanner"
     class="carousel slide carousel-fade banner-slide"
     data-bs-ride="carousel"
     data-bs-interval="3000">

    <div class="carousel-indicators">
        <button type="button" data-bs-target="#mainBanner" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#mainBanner" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#mainBanner" data-bs-slide-to="2"></button>
        <button type="button" data-bs-target="#mainBanner" data-bs-slide-to="3"></button>
        <button type="button" data-bs-target="#mainBanner" data-bs-slide-to="4"></button>
        <button type="button" data-bs-target="#mainBanner" data-bs-slide-to="5"></button>
        <button type="button" data-bs-target="#mainBanner" data-bs-slide-to="6"></button>
        <button type="button" data-bs-target="#mainBanner" data-bs-slide-to="7"></button>
        <button type="button" data-bs-target="#mainBanner" data-bs-slide-to="8"></button>
        <button type="button" data-bs-target="#mainBanner" data-bs-slide-to="9"></button>
    </div>

    <div class="carousel-inner">

        <div class="carousel-item active">
            <img src="@Url.Content("~/Img/banner1.jpg")" class="d-block w-100">
        </div>

        <div class="carousel-item">
            <img src="@Url.Content("~/Img/banner2.jpg")" class="d-block w-100">
        </div>

        <div class="carousel-item">
            <img src="@Url.Content("~/Img/banner3.jpg")" class="d-block w-100">
        </div>

        <div class="carousel-item">
            <img src="@Url.Content("~/Img/banner4.jpg")" class="d-block w-100">
        </div>

        <div class="carousel-item">
            <img src="@Url.Content("~/Img/banner5.jpg")" class="d-block w-100">
        </div>

        <div class="carousel-item">
            <img src="@Url.Content("~/Img/banner6.jpg")" class="d-block w-100">
        </div>

        <div class="carousel-item">
            <img src="@Url.Content("~/Img/banner7.jpg")" class="d-block w-100">
        </div>

        <div class="carousel-item">
            <img src="@Url.Content("~/Img/banner8.jpg")" class="d-block w-100">
        </div>

        <div class="carousel-item">
            <img src="@Url.Content("~/Img/banner9.jpg")" class="d-block w-100">
        </div>

        <div class="carousel-item">
            <img src="@Url.Content("~/Img/banner10.jpg")" class="d-block w-100">
        </div>

    </div>

    <button class="carousel-control-prev"
            type="button"
            data-bs-target="#mainBanner"
            data-bs-slide="prev">

        <span class="carousel-control-prev-icon"></span>

    </button>

    <button class="carousel-control-next"
            type="button"
            data-bs-target="#mainBanner"
            data-bs-slide="next">

        <span class="carousel-control-next-icon"></span>

    </button>

</div>

<div class="movie-section">

    <div class="movie-tabs">

        <button class="tab-btn active"
                onclick="showMovieTab('dangchieu', event)">
            ĐANG CHIẾU
        </button>

        <button class="tab-btn"
                onclick="showMovieTab('sapchieu', event)">
            SẮP CHIẾU
        </button>

    </div>

    <!-- ĐANG CHIẾU -->
    <div id="dangchieu" class="movie-content active">

        <div class="movie-slider">

            <div class="movie-track">

                <a href="@Url.Action("Details","Movies", new { id = 152 })"
                   class="movie-card">
                    <img src="@Url.Content("~/Content/Img/bogiaposter.jpg")" />
                    <div class="movie-info">
                        <h3>Bố Già</h3>
                    </div>
                </a>

                <a href="@Url.Action("Details","Movies", new { id = 153 })"
                   class="movie-card">
                    <img src="@Url.Content("~/Content/Img/nhabanuposter.jpg")" />
                    <div class="movie-info">
                        <h3>Nhà Bà Nữ</h3>
                    </div>
                </a>

                <a href="@Url.Action("Details","Movies", new { id = 155 })"
                   class="movie-card">
                    <img src="@Url.Content("~/Content/Img/doraemonposter.jpg")" />
                    <div class="movie-info">
                        <h3>Doraemon</h3>
                    </div>
                </a>

                <a href="@Url.Action("Details","Movies", new { id = 151 })"
                   class="movie-card">
                    <img src="@Url.Content("~/Content/Img/maipos.jpg")" />
                    <div class="movie-info">
                        <h3>Mai</h3>
                    </div>
                </a>

            </div>

        </div>

    </div>

    <!-- SẮP CHIẾU -->
    <div id="sapchieu" class="movie-content">

        <div class="movie-slider">

            <div class="movie-track">

                <a href="@Url.Action("Details","Movies", new { id = 159 })"
                   class="movie-card">

                    <img src="@Url.Content("~/Content/Img/thamtukienposter.jpg")" />

                    <div class="movie-info">
                        <h3>Thám Tử Kiên</h3>
                    </div>

                </a>

                <a href="@Url.Action("Details","Movies", new { id = 162 })"
                   class="movie-card">

                    <img src="@Url.Content("~/Content/Img/thooiposter.jpg")" />

                    <div class="movie-info">
                        <h3>Thỏ Ơi</h3>
                    </div>

                </a>

                <a href="@Url.Action("Details","Movies", new { id = 158 })"
                   class="movie-card">

                    <img src="@Url.Content("~/Content/Img/sieuluaposter.jpg")" />

                    <div class="movie-info">
                        <h3>Siêu Lừa Gặp Siêu Lầy</h3>
                    </div>

                </a>

                <a href="@Url.Action("Details","Movies", new { id = 160 })"
                   class="movie-card">

                    <img src="@Url.Content("~/Content/Img/latmat8poster.jpg")" />

                    <div class="movie-info">
                        <h3>Lật Mặt 8</h3>
                    </div>

                </a>

            </div>

        </div>

    </div>

</div>

<script>
    function showMovieTab(tabId, event) {

        document.querySelectorAll('.movie-content')
            .forEach(x => x.classList.remove('active'));

        document.querySelectorAll('.tab-btn')
            .forEach(x => x.classList.remove('active'));

        document.getElementById(tabId)
            .classList.add('active');

        event.target.classList.add('active');
    }
</script>