@model IEnumerable<havenix.Models.Movie>

@{
    ViewBag.Title = "Havenix Cinema";

    var movies = Model == null
        ? new List<havenix.Models.Movie>()
        : Model.ToList();

    var dangChieu = movies
        .Where(x => x.Status == "Đang chiếu")
        .Take(4)
        .ToList();

    var sapChieu = movies
        .Where(x => x.Status == "Sắp chiếu")
        .Take(4)
        .ToList();

    if (!dangChieu.Any())
    {
        dangChieu = movies.Take(4).ToList();
    }

    if (!sapChieu.Any())
    {
        sapChieu = movies.Skip(4).Take(4).ToList();
    }
}

<div class="hx-top-ad">
    <img src="@Url.Content("~/Content/Img/zalopay.jpg")" alt="Havenix ưu đãi">
</div>

<div class="hx-film-line"></div>

<div class="hx-side-banner hx-banner-left">
    <img src="@Url.Content("~/Content/Img/anhben.jpg")" alt="Havenix Member Day">
    <img src="@Url.Content("~/Content/Img/anhben.jpg")" alt="Havenix Member Day">
</div>

<div class="hx-side-banner hx-banner-right">
    <img src="@Url.Content("~/Content/Img/anhben.jpg")" alt="Havenix Member Day">
    <img src="@Url.Content("~/Content/Img/anhben.jpg")" alt="Havenix Member Day">
</div>

<!-- BANNER -->
<section class="home-hero">
    <div id="mainBanner"
         class="carousel slide carousel-fade banner-slide"
         data-bs-ride="carousel"
         data-bs-interval="3000">

        <div class="carousel-indicators">
            @for (int i = 0; i < 10; i++)
            {
                <button type="button"
                        data-bs-target="#mainBanner"
                        data-bs-slide-to="@i"
                        class="@(i == 0 ? "active" : "")"></button>
            }
        </div>

        <div class="carousel-inner">
            @for (int i = 1; i <= 10; i++)
            {
                <div class="carousel-item @(i == 1 ? "active" : "")">
                    <img src="@Url.Content("~/Content/Img/banner" + i + ".jpg")" class="d-block w-100">
                </div>
            }
        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#mainBanner" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>

        <button class="carousel-control-next" type="button" data-bs-target="#mainBanner" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>

</section>

<div class="home-booking-center">
    <a href="@Url.Action("Index","Movies")"
       class="btn btn-warning">
        Đặt vé ngay
    </a>
</div>

<!-- MOVIES -->
<section class="movie-section home-movies">

    <div class="section-title">
        <h2>Phim tại HAVENIX</h2>
        <a href="@Url.Action("Index","Movies")">Xem tất cả</a>
    </div>

    <div class="movie-tabs">
        <button class="tab-btn active" onclick="showMovieTab('dangchieu', event)">
            ĐANG CHIẾU
        </button>

        <button class="tab-btn" onclick="showMovieTab('sapchieu', event)">
            SẮP CHIẾU
        </button>
    </div>

    <div id="dangchieu" class="movie-content active">
        <div class="movie-track">

            @foreach (var movie in dangChieu)
            {
                <div class="movie-card">
                    <a href="@Url.Action("Details","Movies", new { id = movie.Id })" class="movie-img-link">
                        <img src="@Url.Content(movie.Image)" alt="@movie.Name" />
                    </a>

                    <div class="movie-info">
                        <h3>@movie.Name</h3>

                        <div class="movie-actions">
                            <a href="@Url.Action("Details","Movies", new { id = movie.Id })">
                                Xem chi tiết
                            </a>

                            @{
                                var firstShowtime = movie.Showtimes?
                                    .OrderBy(x => x.StartTime)
                                    .FirstOrDefault();
                            }

                            @if (firstShowtime != null)
                            {
                                <a href="@Url.Action("Create","Booking",
                                    new { showtimeId = firstShowtime.Id })">
                                    Đặt vé
                                </a>
                            }
                            else
                            {
                                <a href="@Url.Action("Details","Movies",
                                    new { id = movie.Id })">
                                    Chưa có suất
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }

        </div>
    </div>

    <div id="sapchieu" class="movie-content">
        <div class="movie-track">

            @foreach (var movie in sapChieu)
            {
                <div class="movie-card">
                    <a href="@Url.Action("Details","Movies", new { id = movie.Id })" class="movie-img-link">
                        <img src="@Url.Content(movie.Image)" alt="@movie.Name" />
                    </a>

                    <div class="movie-info">
                        <h3>@movie.Name</h3>

                        <div class="movie-actions">
                            <a href="@Url.Action("Details","Movies", new { id = movie.Id })">
                                Xem chi tiết
                            </a>

                            @{
                                var firstShowtime = movie.Showtimes?
                                    .OrderBy(x => x.StartTime)
                                    .FirstOrDefault();
                            }

                            @if (firstShowtime != null)
                            {
                                <a href="@Url.Action("Create","Booking",
                                new { showtimeId = firstShowtime.Id })">
                                    Đặt vé
                                </a>
                            }
                            else
                            {
                                <a href="@Url.Action("Details","Movies",
                                new { id = movie.Id })">
                                    Chưa có suất
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }

        </div>
    </div>

</section>

<script>
    function showMovieTab(tabId, event) {
        document.querySelectorAll('.movie-content')
            .forEach(x => x.classList.remove('active'));

        document.querySelectorAll('.movie-tabs .tab-btn')
            .forEach(x => x.classList.remove('active'));

        document.getElementById(tabId).classList.add('active');
        event.target.classList.add('active');
    }
</script>