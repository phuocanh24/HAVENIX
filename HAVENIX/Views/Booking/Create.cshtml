@model havenix.Models.Showtime

@{
    ViewBag.Title = "Đặt vé phim";
}

<div class="booking-page">

    <div class="booking-card">

        <div class="booking-poster">
            <img src="@Url.Content(Model.Movie.Image)" alt="@Model.Movie.Name" />
        </div>

        <div class="booking-info">

            <h1>@Model.Movie.Name</h1>

            <div class="booking-detail-grid">
                <p><b>Thể loại:</b> @Model.Movie.Genre</p>
                <p><b>Thời lượng:</b> @Model.Movie.Duration phút</p>
                <p><b>Ngôn ngữ:</b> @Model.Movie.Language</p>
                <p><b>Ngày chiếu:</b> @Model.StartTime.ToString("dd/MM/yyyy")</p>
                <p><b>Giờ chiếu:</b> @Model.StartTime.ToString("HH:mm")</p>
                <p><b>Phòng:</b> @Model.Room</p>
            </div>

            <hr />

            <h3>Chọn ghế</h3>

            <div class="seat-status-box">

                <div class="seat-status-item">
                    <span class="seat-demo normal"></span>
                    <b>Ghế thường A-C: 70.000đ</b>
                </div>

                <div class="seat-status-item">
                    <span class="seat-demo vip"></span>
                    <b>Ghế VIP D-H: 85.000đ</b>
                </div>

                <div class="seat-status-item">
                    <span class="seat-demo couple"></span>
                    <b>Ghế đôi I: 160.000đ</b>
                </div>

                <div class="seat-status-item">
                    <span class="seat-demo choosing"></span>
                    <b>Ghế đang chọn</b>
                </div>

                <div class="seat-status-item">
                    <span class="seat-demo sold"></span>
                    <b>Ghế đã đặt</b>
                </div>

            </div>

            <div class="screen">MÀN HÌNH</div>

            <div class="seat-map">

                @for (char row = 'A'; row <= 'H'; row++)
                {
                    <div class="seat-row">
                        @for (int col = 1; col <= 10; col++)
                        {
                            var seatName = row.ToString() + col;
                            var isVip = row >= 'D' && row <= 'H';
                            var seatClass = isVip ? "seat vip-seat" : "seat";
                            var seatPrice = isVip ? 85000 : 70000;

                            <button type="button"
                                    class="@seatClass"
                                    data-seat="@seatName"
                                    data-price="@seatPrice"
                                    onclick="selectSeat(this)">
                                @seatName
                            </button>
                        }
                    </div>
                }

                <div class="couple-row">
                    @for (int col = 1; col <= 6; col++)
                    {
                        var seatName = "I" + col;

                        <button type="button"
                                class="seat couple-seat"
                                data-seat="@seatName"
                                data-price="160000"
                                onclick="selectSeat(this)">
                            @seatName
                        </button>
                    }
                </div>

            </div>

            <div class="booking-summary">
                <p>
                    <b>Ghế đang chọn:</b>
                    <span id="selectedSeats">Chưa chọn</span>
                </p>

                <p>
                    <b>Số lượng:</b>
                    <span id="seatCount">0</span>
                </p>

                <p>
                    <b>Tổng tiền:</b>
                    <span id="totalPrice">0đ</span>
                </p>
            </div>

            <input type="hidden" id="SelectedSeats" name="SelectedSeats" />
            <input type="hidden" id="TotalPrice" name="TotalPrice" />

            <button type="button"
                    class="btn btn-warning confirm-booking"
                    onclick="confirmBooking()">
                Xác nhận đặt vé
            </button>

        </div>

    </div>

</div>

<script>
    let selectedSeats = [];

    const soldSeats = [];

    document.addEventListener("DOMContentLoaded", function () {
        soldSeats.forEach(function (seatName) {
            const seat = document.querySelector(`[data-seat="${seatName}"]`);

            if (seat) {
                seat.classList.add("sold");
                seat.disabled = true;
            }
        });
    });

    function selectSeat(btn) {
        if (btn.classList.contains("sold") || btn.disabled) {
            return;
        }

        const seatName = btn.dataset.seat;
        const seatPrice = parseInt(btn.dataset.price);

        if (btn.classList.contains("selected")) {
            btn.classList.remove("selected");
            selectedSeats = selectedSeats.filter(x => x.name !== seatName);
        } else {
            btn.classList.add("selected");
            selectedSeats.push({
                name: seatName,
                price: seatPrice
            });
        }

        updateBookingSummary();
    }

    function updateBookingSummary() {
        const seatNames = selectedSeats.map(x => x.name);
        const total = selectedSeats.reduce((sum, seat) => sum + seat.price, 0);

        document.getElementById("selectedSeats").innerText =
            seatNames.length > 0 ? seatNames.join(", ") : "Chưa chọn";

        document.getElementById("seatCount").innerText = selectedSeats.length;

        document.getElementById("totalPrice").innerText =
            total.toLocaleString("vi-VN") + "đ";

        document.getElementById("SelectedSeats").value = seatNames.join(",");
        document.getElementById("TotalPrice").value = total;
    }

    function confirmBooking() {
        if (selectedSeats.length === 0) {
            alert("Vui lòng chọn ghế trước khi đặt vé.");
            return;
        }

        const showtimeId = "@Model.Id";
        const seats = encodeURIComponent(selectedSeats.map(x => x.name).join(","));
        const total = selectedSeats.reduce((sum, seat) => sum + seat.price, 0);

        window.location.href = "/Booking/Combos?showtimeId=" + showtimeId
            + "&seats=" + seats
            + "&total=" + total;
    }
</script>