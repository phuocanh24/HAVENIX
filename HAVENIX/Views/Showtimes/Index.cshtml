@model IEnumerable<havenix.Models.Showtime>

@{
    ViewBag.Title = "Lịch chiếu";

    var byDate = Model
        .GroupBy(x => x.StartTime.Date)
        .OrderBy(x => x.Key)
        .ToList();
}

<div class="showtime-page">

    <div class="showtime-header">

        <h1>LỊCH CHIẾU PHIM</h1>

        <p>
            Chọn ngày và suất chiếu phù hợp để đặt vé nhanh chóng.
        </p>

    </div>

    <div class="date-tabs">

        @foreach (var day in byDate)
        {
            <button type="button"
                    class="tab-btn"
                    data-day="@day.Key.ToString("yyyy-MM-dd")"
                    onclick="showDay(this)">

                <span>@day.Key.ToString("dd/MM")</span>
                <small>@day.Key.ToString("dddd")</small>

            </button>
        }

    </div>

    @foreach (var day in byDate)
    {
        <div class="time-group"
             data-day="@day.Key.ToString("yyyy-MM-dd")"
             style="display:none">

            @{
                var byMovie = day.GroupBy(x => x.Movie).ToList();
            }

            @foreach (var movieGroup in byMovie)
            {
                <div class="schedule-card">

                    <div class="schedule-left">

                        <a href="@Url.Action("Details","Movies",
                           new { id = movieGroup.Key.Id })">

                            <img src="@Url.Content(movieGroup.Key.Image)"
                                 class="schedule-img" />

                        </a>

                    </div>

                    <div class="schedule-info">

                        <h3>@movieGroup.Key.Name</h3>

                        <div class="schedule-meta">

                            <span>@movieGroup.Key.Genre</span>

                            <span>@movieGroup.Key.Duration</span>

                        </div>

                        <div class="time-list">

                            @foreach (var item in movieGroup.OrderBy(x => x.StartTime))
                            {
                                <a href="@Url.Action("Create","Booking",
                                   new { showtimeId = item.Id })"
                                   class="time-btn">

                                    <strong>
                                        @item.StartTime.ToString("HH:mm")
                                    </strong>

                                    <small>
                                        @item.Room
                                    </small>

                                </a>
                            }

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>

<script>
    function showDay(btn) {

        let day = btn.getAttribute("data-day");

        document.querySelectorAll(".date-tabs .tab-btn")
            .forEach(x => x.classList.remove("active"));

        btn.classList.add("active");

        document.querySelectorAll(".time-group")
            .forEach(x => x.style.display = "none");

        let target = document.querySelector(
            ".time-group[data-day='" + day + "']"
        );

        if (target)
            target.style.display = "block";
    }

    document.addEventListener("DOMContentLoaded", function () {

        let first =
            document.querySelector(".date-tabs .tab-btn");

        if (first)
            first.click();

    });
</script>