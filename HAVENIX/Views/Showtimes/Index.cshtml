@model IEnumerable<havenix.Models.Showtime>

@{
    var byDate = Model
        .GroupBy(x => x.StartTime.Date)
        .OrderBy(x => x.Key)
        .ToList();
}

<div class="showtime-container">

    <h2>Lịch chiếu</h2>

    <div class="date-tabs">
        @foreach (var day in byDate)
        {
            <button type="button"
                    class="tab-btn"
                    data-day="@day.Key.ToString("yyyy-MM-dd")"
                    onclick="showDay(this)">
                @day.Key.ToString("dd/MM")
            </button>
        }
    </div>

    @foreach (var day in byDate)
    {
        <div class="time-group"
             data-day="@day.Key.ToString("yyyy-MM-dd")"
             style="display:none">

            <h3>@day.Key.ToString("dddd - dd/MM")</h3>

            @{
                var byMovie = day.GroupBy(x => x.Movie).ToList();
            }

            @foreach (var movieGroup in byMovie)
            {
                <div class="schedule-card">

                    <a href="/Movies/Details/@movieGroup.Key.Id">
                        <img src="@movieGroup.Key.Image" class="schedule-img" />
                    </a>

                    <div class="schedule-info">
                        <h4>@movieGroup.Key.Name</h4>

                        <div class="time-list">
                            @foreach (var item in movieGroup)
                            {
                                <a href="/Movies/Details/@item.MovieId" class="time-btn">
                                    @item.StartTime.ToString("HH:mm") | @item.Room
                                </a>
                            }
                        </div>
                    </div>

                </div>
            }

        </div>
    }

</div>

<script>
    function showDay(btn) {
        let day = btn.getAttribute("data-day");

        document.querySelectorAll(".date-tabs .tab-btn")
            .forEach(b => b.classList.remove("active"));

        btn.classList.add("active");

        document.querySelectorAll(".time-group")
            .forEach(x => x.style.display = "none");

        let target = document.querySelector(".time-group[data-day='" + day + "']");
        if (target) target.style.display = "block";
    }

    window.onload = function () {
        let first = document.querySelector(".date-tabs .tab-btn");
        if (first) first.click();
    }
</script>